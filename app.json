{
  "expo": {
    "name": "FruitSense",
    "slug": "fruitsense",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F6FBF3"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.kchipanach.fruitsense"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "FruitSense necesita acceder a tus fotos para analizar la fruta.",
          "cameraPermission": "FruitSense necesita la camara para tomar fotos de la fruta."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "807a51fd-5630-44b6-9aa0-3c3796824b37"
      }
    },
    "owner": "kchipanach",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/807a51fd-5630-44b6-9aa0-3c3796824b37"
    }
  }
}
